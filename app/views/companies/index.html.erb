<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= t("companies.index.title") %></h1>
      <p class="mt-1 text-gray-600"><%= t("companies.index.description") %></p>
    </div>
    <%= link_to new_company_path,
        class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500 transition-colors" do %>
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      <%= t("companies.new_button") %>
    <% end %>
  </div>

  <% if @companies.any? %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("companies.fields.name") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("companies.fields.nit") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("companies.fields.employees_count") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("companies.fields.actions") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @companies.each do |company| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4 text-sm font-medium text-gray-900">
                <%= link_to company.name, company, class: "text-indigo-600 hover:text-indigo-800" %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= company.nit %></td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= company.employees.size %></td>
              <td class="px-6 py-4 text-sm text-right space-x-3">
                <%= link_to t("companies.actions.edit"), edit_company_path(company),
                    class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
                <%= link_to t("companies.actions.delete"), company,
                    data: { turbo_method: :delete, turbo_confirm: t("companies.confirm_delete") },
                    class: "text-red-600 hover:text-red-800 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900"><%= t("companies.empty.title") %></h3>
      <p class="mt-1 text-sm text-gray-500"><%= t("companies.empty.description") %></p>
    </div>
  <% end %>
</div>
