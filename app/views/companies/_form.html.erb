<%= form_with model: company, class: "space-y-6" do |f| %>
  <% if company.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" />
        </svg>
        <div class="ml-3">
          <ul class="list-disc pl-5 space-y-1 text-sm text-red-700">
            <% company.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :name, t("companies.fields.name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none", placeholder: t("companies.placeholders.name") %>
  </div>

  <div>
    <%= f.label :nit, t("companies.fields.nit"), class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :nit, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none", placeholder: t("companies.placeholders.nit") %>
  </div>

  <div class="border-t border-gray-200 pt-6 mt-6">
    <h3 class="text-sm font-semibold text-gray-700 mb-4"><%= t("companies.fields.payroll_section") %></h3>

    <div class="grid grid-cols-3 gap-4">
      <div>
        <%= f.label :payroll_prefix, t("companies.fields.payroll_prefix"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :payroll_prefix, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none", placeholder: "NM" %>
        <p class="mt-1 text-xs text-gray-500"><%= t("companies.hints.payroll_prefix") %></p>
      </div>

      <div>
        <%= f.label :payroll_code, t("companies.fields.payroll_code"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :payroll_code, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none", placeholder: company.name.to_s.split(/\s+/).first.to_s.upcase %>
        <p class="mt-1 text-xs text-gray-500"><%= t("companies.hints.payroll_code") %></p>
      </div>

      <div>
        <%= f.label :last_payroll_consecutive, t("companies.fields.last_payroll_consecutive"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :last_payroll_consecutive, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none", min: 0 %>
        <p class="mt-1 text-xs text-gray-500"><%= t("companies.hints.last_payroll_consecutive") %></p>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= f.submit class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500 transition-colors cursor-pointer" %>
    <%= link_to t("companies.cancel"), (company.persisted? ? company : companies_path),
        class: "text-sm font-medium text-gray-600 hover:text-gray-800" %>
  </div>
<% end %>
