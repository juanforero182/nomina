<div class="flex flex-col items-center justify-center min-h-[70vh] text-center">
  <svg class="w-20 h-20 text-amber-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.049.58.025 1.193-.14 1.743" />
  </svg>

  <div class="mt-4 flex items-center gap-2">
    <div class="flex gap-1">
      <span class="w-2 h-2 rounded-full bg-amber-400 animate-bounce" style="animation-delay: 0s;"></span>
      <span class="w-2 h-2 rounded-full bg-amber-400 animate-bounce" style="animation-delay: 0.15s;"></span>
      <span class="w-2 h-2 rounded-full bg-amber-400 animate-bounce" style="animation-delay: 0.3s;"></span>
    </div>
  </div>

  <h1 class="mt-6 text-2xl font-bold text-gray-900"><%= module_name %></h1>

  <p class="mt-3 max-w-sm text-gray-600 leading-relaxed">
    <%= t("shared.work_in_progress.message") %>
  </p>

  <p class="mt-6 text-sm text-gray-400">
    <span class="font-semibold text-gray-500">Hohem Tecnologia SAS</span>
  </p>
</div>
