<%= form_with model: (company ? [company, employee] : employee), class: "space-y-6" do |f| %>
  <% if employee.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" />
        </svg>
        <div class="ml-3">
          <ul class="list-disc pl-5 space-y-1 text-sm text-red-700">
            <% employee.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Identification %>
  <fieldset class="border border-gray-200 rounded-md p-4">
    <legend class="text-sm font-semibold text-gray-700 px-2"><%= t("employees.form.identification") %></legend>
    <div class="grid grid-cols-2 gap-4 mt-2">
      <div>
        <%= f.label :document_type, t("employees.fields.document_type"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :document_type,
            Employee::DOCUMENT_TYPES.map { |k, v| ["#{v} - #{k}", k] },
            {},
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none bg-white" %>
      </div>
      <div>
        <%= f.label :document_number, t("employees.fields.document_number"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :document_number, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
    </div>
  </fieldset>

  <%# Personal info %>
  <fieldset class="border border-gray-200 rounded-md p-4">
    <legend class="text-sm font-semibold text-gray-700 px-2"><%= t("employees.form.personal_info") %></legend>
    <div class="grid grid-cols-2 gap-4 mt-2">
      <div>
        <%= f.label :first_surname, t("employees.fields.first_surname"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :first_surname, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= f.label :second_surname, t("employees.fields.second_surname"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :second_surname, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= f.label :first_name, t("employees.fields.first_name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :first_name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= f.label :other_names, t("employees.fields.other_names"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :other_names, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
    </div>
  </fieldset>

  <%# Contact %>
  <fieldset class="border border-gray-200 rounded-md p-4">
    <legend class="text-sm font-semibold text-gray-700 px-2"><%= t("employees.form.contact") %></legend>
    <div class="grid grid-cols-2 gap-4 mt-2">
      <div>
        <%= f.label :email, t("employees.fields.email"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= f.label :mobile, t("employees.fields.mobile"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :mobile, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= f.label :phone, t("employees.fields.phone"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :phone, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= f.label :gender, t("employees.fields.gender"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :gender, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
      <div class="col-span-2">
        <%= f.label :address, t("employees.fields.address"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :address, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" %>
      </div>
    </div>
  </fieldset>

  <div class="flex items-center gap-3 pt-4">
    <%= f.submit class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500 transition-colors cursor-pointer" %>
    <% cancel_path = if company && employee.persisted?
        company_employee_path(company, employee)
      elsif company
        company_path(company)
      elsif employee.persisted?
        employee_path(employee)
      else
        employees_path
      end %>
    <%= link_to t("employees.cancel"), cancel_path,
        class: "text-sm font-medium text-gray-600 hover:text-gray-800" %>
  </div>
<% end %>
