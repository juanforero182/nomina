<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= t("employees.index.title") %></h1>
      <% if @company %>
        <p class="mt-1 text-gray-600"><%= @company.name %></p>
      <% else %>
        <p class="mt-1 text-gray-600"><%= t("employees.index.description") %></p>
      <% end %>
    </div>
    <% if @company %>
      <%= link_to new_company_employee_path(@company),
          class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500 transition-colors" do %>
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        <%= t("employees.new_button") %>
      <% end %>
    <% end %>
  </div>

  <% if @employees.any? %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <% unless @company %>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("employees.fields.company") %></th>
            <% end %>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("employees.fields.document") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("employees.fields.full_name") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("employees.fields.position") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("employees.fields.hire_date") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("employees.fields.contract_type") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("employees.fields.actions") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @employees.each do |employee| %>
            <% latest = employee.latest_contract %>
            <tr class="hover:bg-gray-50 transition-colors">
              <% unless @company %>
                <td class="px-6 py-4 text-sm text-gray-600">
                  <%= link_to employee.company.name, company_path(employee.company), class: "text-indigo-600 hover:text-indigo-800" %>
                </td>
              <% end %>
              <td class="px-6 py-4 text-sm text-gray-600">
                <span class="text-xs font-medium text-gray-400"><%= employee.document_type_label %></span>
                <%= employee.document_number %>
              </td>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">
                <% if @company %>
                  <%= link_to employee.full_name, [@company, employee], class: "text-indigo-600 hover:text-indigo-800" %>
                <% else %>
                  <%= link_to employee.full_name, employee, class: "text-indigo-600 hover:text-indigo-800" %>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= latest&.position || "-" %></td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= latest&.contract_date ? l(latest.contract_date, format: :short) : "-" %></td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= latest&.contract_type_label || "-" %></td>
              <td class="px-6 py-4 text-sm text-right space-x-3">
                <% if @company %>
                  <%= link_to t("employees.actions.edit"), edit_company_employee_path(@company, employee),
                      class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
                  <%= link_to t("employees.actions.delete"), [@company, employee],
                      data: { turbo_method: :delete, turbo_confirm: t("employees.confirm_delete") },
                      class: "text-red-600 hover:text-red-800 font-medium" %>
                <% else %>
                  <%= link_to t("employees.actions.edit"), edit_employee_path(employee),
                      class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
                  <%= link_to t("employees.actions.delete"), employee,
                      data: { turbo_method: :delete, turbo_confirm: t("employees.confirm_delete") },
                      class: "text-red-600 hover:text-red-800 font-medium" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900"><%= t("employees.empty.title") %></h3>
      <p class="mt-1 text-sm text-gray-500"><%= t("employees.empty.description") %></p>
    </div>
  <% end %>
</div>
