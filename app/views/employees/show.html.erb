<div class="max-w-3xl mx-auto">
  <div class="mb-6">
    <% if @company %>
      <%= link_to @company, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700" do %>
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
        <%= @company.name %>
      <% end %>
    <% else %>
      <%= link_to employees_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700" do %>
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
        <%= t("employees.back") %>
      <% end %>
    <% end %>
  </div>

  <%# Personal data card %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-bold text-gray-900"><%= @employee.full_name %></h1>
      <div class="flex items-center gap-3">
        <% edit_path = @company ? edit_company_employee_path(@company, @employee) : edit_employee_path(@employee) %>
        <%= link_to t("employees.actions.edit"), edit_path,
            class: "inline-flex items-center gap-1 rounded-md bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50 transition-colors" %>
        <% delete_path = @company ? [@company, @employee] : @employee %>
        <%= link_to t("employees.actions.delete"), delete_path,
            data: { turbo_method: :delete, turbo_confirm: t("employees.confirm_delete") },
            class: "inline-flex items-center gap-1 rounded-md bg-red-50 px-3 py-2 text-sm font-medium text-red-700 shadow-sm ring-1 ring-red-200 hover:bg-red-100 transition-colors" %>
      </div>
    </div>

    <div class="space-y-6">
      <%# Company %>
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3"><%= t("employees.fields.company") %></h3>
        <p class="text-sm text-gray-900">
          <%= link_to @employee.company.name, company_path(@employee.company), class: "text-indigo-600 hover:text-indigo-800" %>
          <span class="text-gray-400 ml-2">NIT: <%= @employee.company.nit %></span>
        </p>
      </div>

      <%# Identification %>
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3"><%= t("employees.form.identification") %></h3>
        <dl class="grid grid-cols-2 gap-4">
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.document_type") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.document_type_label %> (<%= @employee.document_type %>)</dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.document_number") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.document_number %></dd>
          </div>
        </dl>
      </div>

      <%# Personal info %>
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3"><%= t("employees.form.personal_info") %></h3>
        <dl class="grid grid-cols-2 gap-4">
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.first_surname") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.first_surname %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.second_surname") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.second_surname || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.first_name") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.first_name %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.other_names") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.other_names.presence || "-" %></dd>
          </div>
        </dl>
      </div>

      <%# Contact %>
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3"><%= t("employees.form.contact") %></h3>
        <dl class="grid grid-cols-2 gap-4">
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.email") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.email.presence || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.mobile") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.mobile.presence || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.phone") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.phone.presence || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.gender") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.gender.presence || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500"><%= t("employees.fields.address") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @employee.address.presence || "-" %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <%# Contracts section %>
  <div class="mb-4">
    <h2 class="text-lg font-semibold text-gray-900"><%= t("contracts.title") %> (<%= @employee.contracts.size %>)</h2>
  </div>

  <% @employee.contracts.latest.each do |contract| %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-4">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <h3 class="text-sm font-bold text-gray-900"><%= contract.contract_number || t("contracts.no_number") %></h3>
          <% if contract.active? %>
            <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-green-600/20">Activo</span>
          <% else %>
            <span class="inline-flex items-center rounded-full bg-red-50 px-2 py-1 text-xs font-medium text-red-700 ring-1 ring-red-600/20">Inactivo</span>
          <% end %>
        </div>
        <span class="text-xs text-gray-400"><%= contract.contract_type_label %></span>
      </div>

      <div class="space-y-4">
        <%# Employment %>
        <dl class="grid grid-cols-3 gap-4">
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.position") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= contract.position || "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.basic_salary") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= contract.basic_salary ? number_to_currency(contract.basic_salary, unit: "$", precision: 0) : "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.area") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= contract.area || "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.contract_date") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= contract.contract_date ? l(contract.contract_date, format: :short) : "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.contract_end_date") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= contract.contract_end_date ? l(contract.contract_end_date, format: :short) : "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.integral_salary") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= contract.integral_salary ? t("employees.yes") : t("employees.no") %></dd>
          </div>
        </dl>

        <%# Social security %>
        <dl class="grid grid-cols-3 gap-4 pt-3 border-t border-gray-100">
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.health_entity") %></dt>
            <dd class="mt-1 text-sm text-gray-900 truncate" title="<%= contract.health_entity %>"><%= contract.health_entity || "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.pension_entity") %></dt>
            <dd class="mt-1 text-sm text-gray-900 truncate" title="<%= contract.pension_entity %>"><%= contract.pension_entity || "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.arl_entity") %></dt>
            <dd class="mt-1 text-sm text-gray-900 truncate" title="<%= contract.arl_entity %>"><%= contract.arl_entity || "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.compensation_fund") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= contract.compensation_fund || "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.bank_name") %></dt>
            <dd class="mt-1 text-sm text-gray-900 truncate" title="<%= contract.bank_name %>"><%= contract.bank_name || "-" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-500"><%= t("contracts.fields.bank_account") %></dt>
            <dd class="mt-1 text-sm text-gray-900"><%= contract.bank_account || "-" %></dd>
          </div>
        </dl>
      </div>
    </div>
  <% end %>

  <% if @employee.contracts.empty? %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8 text-center">
      <p class="text-sm text-gray-500"><%= t("contracts.empty") %></p>
    </div>
  <% end %>
</div>
